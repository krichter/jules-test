# Flask specific
FLASK_APP=run.py
FLASK_ENV=development # change to 'production' for deployment

# Application specific
SECRET_KEY=your_very_secret_and_unique_key_here
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:your_db_port/your_db_name

# For testing (if using a separate test database, otherwise :memory: is default in TestConfig)
# TEST_DATABASE_URL=postgresql://your_test_db_user:your_test_db_password@your_db_host:your_db_port/your_test_db_name
